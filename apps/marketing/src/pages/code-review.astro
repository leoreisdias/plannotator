---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import GitHubStars from '../components/landing/GitHubStars';

// The page runs as two arcs (research-backed ordering): the fully manual
// tool first, since control is the credibility floor for reviewers in the
// agent era; then the AI layer, ordered from weakest claim of autonomy
// (inline Q&A) to strongest (agent-run reviews), so trust builds rung by
// rung. Screenshots alternate sides continuously across both arcs.
const coreFeatures = [
  {
    id: 'annotations',
    eyebrow: 'annotate → agent',
    title: 'Your annotations become the agent\'s instructions',
    body: [
      'Select lines, a single token, or a whole file and leave a comment, a concern, or a code suggestion. Conventional Comments labels are there if your team writes reviews that way.',
      'When you hit Send Feedback, everything exports as markdown anchored to exact files and lines and lands in your agent session. The agent reads it like any other instruction and gets to work.',
    ],
    points: ['Line, token, file, and review-level scopes', 'Suggested-code blocks with the original alongside', 'Drafts auto-save and survive a crashed session'],
    img: '/assets/code-review/annotations.png',
    alt: 'A selected diff range with a comment popover and a suggested-code block',
  },
  {
    id: 'all-changes',
    eyebrow: 'git status view',
    title: 'Review the whole change before it\'s a PR',
    body: [
      'The default view pulls together everything you\'ve touched: committed work, uncommitted edits, and untracked files, in one screen. No need to commit, push, or open a PR first, you see exactly what a PR would show while the work is still in progress.',
      'It\'s grouped the way git status groups it: a Committed section, a Changes section, an Untracked section. Every row shows the change type and line counts, and you can stage or unstage files right there while you review.',
    ],
    points: ['Falls back gracefully when no base branch resolves', 'One-click fetch when the base is behind GitHub'],
    img: '/assets/code-review/git-status.png',
    alt: 'The git status panel showing Committed, Changes, and Untracked sections beside an open diff',
  },
  {
    id: 'commits',
    eyebrow: 'commits panel',
    title: 'Walk the branch, one commit at a time',
    body: [
      'The Commits panel is a plain history rail of your branch, newest first, with a divider where your work meets the base. Click any commit and you get that commit\'s own diff against its parent, with the full commit message on top.',
      'It\'s git show with annotations. Review a teammate\'s commit, or your own from last Tuesday, and the feedback records which commit each note was anchored to.',
    ],
    points: ['Session-scoped: glancing at history never changes your default view'],
    img: '/assets/code-review/commits.png',
    alt: 'The commits rail with avatars beside a per-commit diff and its rendered message',
  },
  {
    id: 'pr-review',
    eyebrow: 'pull requests',
    title: 'Review PRs without the noise',
    body: [
      'Point it at a GitHub PR or a GitLab MR and it opens in the same viewer: the description, checks, and full discussion in one Overview panel. On a busy PR the discussion is where you drown, so the comments column filters it down. Hide bots (Dependabot, CI, Copilot) with one toggle, drop resolved and outdated threads, narrow to specific people, or search the whole thread.',
      'The description and comments are annotatable too. The agent can\'t see the PR discussion on its own, so your notes travel with the full comment quoted. Post your review back to the platform as inline comments, or hand it to the agent to fix.',
    ],
    points: ['Hide bots is on by default; resolved and outdated threads collapse away', 'Uses your gh / glab auth, so private repos just work', 'Stacked PRs get a Layer / Full-stack toggle for the whole chain'],
    img: '/assets/code-review/pr-review.png',
    alt: 'The PR overview panel with description, checks, and annotatable comments',
  },
];

const aiFeatures = [
  {
    id: 'ask-ai',
    eyebrow: 'ask ai',
    title: 'Ask the diff a question',
    body: [
      'Select lines in the diff and ask. The answer streams into a side panel, scoped to the code you selected and the changeset on screen, riding whichever agent CLI you already use.',
      'It\'s reading support, not delegation. You stay in the diff; the model holds the context you would otherwise go dig for.',
    ],
    points: ['Providers detected from the CLIs you already have installed', 'Answers stay grouped by file for the session'],
    img: '/assets/code-review/ask-ai.png',
    alt: 'Selected diff lines with an Ask AI answer streaming into the side panel',
  },
  {
    id: 'guided-review',
    eyebrow: 'guided review',
    title: 'Let an agent chapter the changeset',
    body: [
      'A Guided Review has an agent reorganize the changeset into chapters by importance: the heart of the change first, then its consequences, then the glue. Each chapter pairs a short overview and per-file summaries with the diffs it covers. On a big diff it reads far better than file order.',
      'The diffs inside a guide are the real diff viewer, not excerpts. You still read every line; the agent just puts the lines in a smarter order. Anything you annotate there lands in the same review and ships in the same feedback.',
    ],
    points: ['Per-section reviewed state for multi-sitting reviews', 'Every changed file validated against the real diff'],
    img: '/assets/code-review/guided-review.png',
    alt: 'A guided review section: prose overview on the left, live annotatable diff on the right',
  },
  {
    id: 'agent-reviews',
    eyebrow: 'agent reviews',
    title: 'Run review agents, keep the final say',
    body: [
      'Kick off a review agent against the current changeset and its findings come back as annotations on the diff, each with a severity, the reasoning behind it, and a file and line anchor. You decide what to keep. Nothing gets sent anywhere until you send it.',
      'The review is yours to define. Point it at one of your own skills, your team\'s security checklist, your naming conventions, whatever you\'ve written, and that skill becomes a launchable reviewer whose findings land as inline diff comments exactly like the built-in one. Runs on Claude or Codex natively, or through Cursor, OpenCode, Pi, and GitHub Copilot CLI when they\'re on your PATH.',
    ],
    points: ['Bring your own review skill; its findings land as diff comments', 'Code Tours: a narrated walkthrough with checkpoints', 'Run several engines on the same diff and compare findings'],
    img: '/assets/code-review/agent-reviews.png',
    alt: 'The review agents tab with engine choices and agent findings in the annotations sidebar',
  },
];

// Chapter markers. The title-voice shift between the two is deliberate:
// part one stays in tool-description register, part two names the handoff.
const arcs = [
  {
    id: 'core',
    eyebrow: 'part one',
    title: 'The manual tool',
    sub: 'Review any changeset with nothing between you and the diff. No model in the loop unless you put one there.',
    items: coreFeatures,
  },
  {
    id: 'ai',
    eyebrow: 'part two',
    title: 'The AI layer',
    sub: 'Same viewer, same annotations, more eyes on the code. Agents flag; you decide what ships.',
    items: aiFeatures,
  },
];

const features = arcs.flatMap((a) => a.items);
// AI-layer features get a slanted "AI" mark on their badges + eyebrows.
const aiIds = new Set(aiFeatures.map((f) => f.id));

const title = 'Code Review · Plannotator';
const description =
  'Review agent-written code in a real diff viewer: a git-status view of everything since main, guided reviews, per-commit diffs, launchable review agents, and PR reviews. Feedback goes straight back to your agent.';
---

<Base title={title} description={description}>
  <div class="min-h-screen bg-background text-foreground">
    <Nav />

    <main class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="cr-hero-wrap">
      <!-- ── Demo video launcher (right of the hero, vertically centered) ── -->
      <button class="cr-demo-launch" type="button" aria-label="Watch the two-minute code review demo" data-open-demo>
        <img src="/assets/code-review-demo-poster.jpg" alt="" class="cr-demo-poster" loading="eager" width="640" height="360" />
        <span class="cr-demo-play" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
        </span>
        <span class="cr-demo-caption">Watch the 2-min demo</span>
      </button>

      <!-- ── Hero ── -->
      <header class="cr-hero">
        <div class="cr-cmd-row">
          <p class="cr-cmd">/plannotator-review <span class="cr-cmd-dim">[PR_URL]</span></p>
          <a
            href="https://github.com/backnotprop/plannotator"
            target="_blank"
            rel="noopener noreferrer"
            class="cr-gh"
            aria-label="Plannotator on GitHub"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z"/></svg>
            <GitHubStars client:load />
          </a>
        </div>
        <h1 class="font-display cr-heading">
          Code review for<br />the modern era.
        </h1>
        <p class="cr-overview">
          Plannotator opens every change your agent makes in a local diff viewer. You mark up
          what's wrong, and your notes go back to the agent as instructions. The core tool is
          fully manual and works on local diffs, branches, single commits, and pull requests.
          The AI layer on top is optional, and it answers to you. Free, open source, and it
          runs entirely on your machine.
        </p>

        <div class="cr-vcs-badges">
          <span class="cr-badge cr-badge-plain">git</span>
          <span class="cr-badge" title="Jujutsu repos get native jj diff modes">jj</span>
          <span class="cr-badge" title="Perforce changelists supported">Perforce</span>
        </div>

        <dl class="cr-caps">
          <div class="cr-cap">
            <dt class="cr-cap-label">review agents</dt>
            <dd class="cr-cap-val cr-agent-icons">
              <img src="/assets/icon-claude.svg" alt="Claude" title="Claude" draggable="false" />
              <img src="/assets/icon-codex.png" alt="Codex" title="Codex" class="rounded-sm" draggable="false" />
              <img src="/assets/icon-opencode-dark.svg" alt="OpenCode" title="OpenCode" class="icon-opencode" draggable="false" />
              <img src="/assets/icon-pi.svg" alt="Pi" title="Pi" class="icon-pi" draggable="false" />
              <img src="/assets/icon-copilot.svg" alt="GitHub Copilot CLI" title="GitHub Copilot CLI" class="icon-copilot" draggable="false" />
              <img src="/assets/icon-gemini.png" alt="Gemini CLI" title="Gemini CLI" draggable="false" />
              <img src="/assets/icon-droid.png" alt="Droid" title="Droid" class="rounded-sm" draggable="false" />
              <img src="/assets/icon-amp.svg" alt="Amp" title="Amp" draggable="false" />
              <img src="/assets/icon-kiro.svg" alt="Kiro" title="Kiro" class="rounded-sm" draggable="false" />
              <img src="/assets/icon-vscode.svg" alt="VS Code" title="VS Code" draggable="false" />
            </dd>
          </div>
          <div class="cr-cap">
            <dt class="cr-cap-label">custom reviews</dt>
            <dd class="cr-cap-val cr-cap-text">
              Bring your own skills. They run in the background and leave findings as inline diff comments.
            </dd>
          </div>
        </dl>

        <nav class="cr-toc" aria-label="Features on this page">
          {features.map((f) => (
            <a href={`#${f.id}`} class="cr-toc-item">
              {aiIds.has(f.id) && <span class="cr-ai-mark">AI</span>}
              {f.title}
            </a>
          ))}
        </nav>
      </header>
      </div>

      <!-- ── Two arcs: manual tool, then AI layer ── -->
      {arcs.map((arc, arcIdx) => (
        <Fragment>
          <div class="cr-arc" id={`arc-${arc.id}`}>
            <p class="cr-arc-eyebrow">{arc.eyebrow}</p>
            <h2 class="font-display cr-arc-title">{arc.title}</h2>
            <p class="cr-arc-sub">{arc.sub}</p>
          </div>
          {arc.items.map((f, i) => {
            const gi = (arcIdx === 0 ? 0 : coreFeatures.length) + i;
            return (
        <section id={f.id} class="cr-section">
          <div class:list={['cr-grid', gi % 2 === 1 && 'cr-grid-flip']}>
            <div class="cr-copy">
              <p class="cr-eyebrow">
                {aiIds.has(f.id) && <span class="cr-ai-mark">AI</span>}
                {f.eyebrow}
              </p>
              <h2 class="font-display cr-title">{f.title}</h2>
              {f.body.map((p) => (
                <p class="cr-body">{p}</p>
              ))}
              {f.points && (
                <ul class="cr-points">
                  {f.points.map((pt) => (
                    <li>{pt}</li>
                  ))}
                </ul>
              )}
            </div>
            <figure class="cr-shot">
              <button
                type="button"
                class="cr-shot-btn"
                data-lightbox={f.img}
                data-lightbox-alt={f.alt}
                aria-label={`View ${f.alt} full size`}
              >
                <img src={f.img} alt={f.alt} width="1600" height="1000" loading={gi === 0 ? 'eager' : 'lazy'} />
                <span class="cr-shot-zoom" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
                  </svg>
                </span>
              </button>
            </figure>
          </div>
        </section>
            );
          })}
        </Fragment>
      ))}

      <!-- ── Integration ── -->
      <section id="integrations" class="cr-integrations">
        <p class="cr-eyebrow">integrations</p>
        <h2 class="font-display cr-title">Agents can talk to it from the outside, too</h2>
        <p class="cr-body cr-int-lede">
          The AI you run inside Plannotator isn't the only thing that can touch a review. Through
          a small HTTP API, anything outside, another agent, your CI, a linter, a script, can POST
          findings straight onto the diff. They stream in live and land inline, tagged by where
          they came from, right next to your own notes.
        </p>

        <figure class="cr-int-figure">
          <svg viewBox="0 0 980 340" class="cr-int-svg" role="img"
            aria-label="External tools POST annotations into a live Plannotator review; the findings appear inline on the diff, tagged by source.">
            <defs>
              <marker id="cri-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                <path d="M0 0 L10 5 L0 10 z" class="cri-arrowhead" />
              </marker>
            </defs>

            <!-- Source nodes -->
            <g class="cri-source">
              <rect x="8" y="18" width="204" height="54" rx="11" class="cri-pill" />
              <text x="28" y="42" class="cri-pill-title">Other agents</text>
              <text x="28" y="60" class="cri-pill-sub">background · CI</text>
            </g>
            <g class="cri-source">
              <rect x="8" y="92" width="204" height="54" rx="11" class="cri-pill" />
              <text x="28" y="116" class="cri-pill-title">CI &amp; checks</text>
              <text x="28" y="134" class="cri-pill-sub">status · coverage</text>
            </g>
            <g class="cri-source">
              <rect x="8" y="166" width="204" height="54" rx="11" class="cri-pill" />
              <text x="28" y="190" class="cri-pill-title">Linters, scanners</text>
              <text x="28" y="208" class="cri-pill-sub">ESLint · Semgrep</text>
            </g>
            <g class="cri-source">
              <rect x="8" y="240" width="204" height="54" rx="11" class="cri-pill" />
              <text x="28" y="264" class="cri-pill-title">Your scripts</text>
              <text x="28" y="282" class="cri-pill-sub">post anything</text>
            </g>

            <!-- Wires converging on the ingest node -->
            <path d="M212 45 C 320 45, 372 175, 448 175" class="cri-wire" />
            <path d="M212 119 C 320 119, 372 175, 448 175" class="cri-wire" />
            <path d="M212 193 C 320 193, 372 175, 448 175" class="cri-wire" />
            <path d="M212 267 C 320 267, 372 175, 448 175" class="cri-wire" marker-end="url(#cri-arrow)" />

            <!-- Ingest node -->
            <rect x="450" y="150" width="118" height="50" rx="10" class="cri-hub" />
            <text x="509" y="172" class="cri-hub-title">POST</text>
            <text x="509" y="190" class="cri-hub-sub">JSON</text>
            <text x="509" y="232" class="cri-endpoint">/api/external-annotations</text>

            <!-- Arrow into the review -->
            <path d="M568 175 L 624 175" class="cri-wire" marker-end="url(#cri-arrow)" />

            <!-- Review card -->
            <rect x="628" y="30" width="344" height="280" rx="14" class="cri-card" />
            <text x="652" y="64" class="cri-card-title">Your live review</text>
            <line x1="628" y1="80" x2="972" y2="80" class="cri-card-rule" />

            <g>
              <circle cx="664" cy="118" r="5" class="cri-dot cri-dot-a" />
              <text x="682" y="114" class="cri-ann-src">agent</text>
              <text x="682" y="132" class="cri-ann-body">possible race in the retry path</text>
            </g>
            <g>
              <circle cx="664" cy="176" r="5" class="cri-dot cri-dot-b" />
              <text x="682" y="172" class="cri-ann-src">semgrep</text>
              <text x="682" y="190" class="cri-ann-body">taint: req.params flows to fs.read</text>
            </g>
            <g>
              <circle cx="664" cy="234" r="5" class="cri-dot cri-dot-c" />
              <text x="682" y="230" class="cri-ann-src">ci</text>
              <text x="682" y="248" class="cri-ann-body">coverage on this file dropped 4%</text>
            </g>
            <g>
              <circle cx="664" cy="284" r="5" class="cri-dot cri-dot-you" />
              <text x="682" y="280" class="cri-ann-src cri-ann-you">you</text>
              <text x="682" y="298" class="cri-ann-body">let's pull this into a helper</text>
            </g>
          </svg>
        </figure>
      </section>

      <!-- ── Compound engineering ── -->
      <section id="compound" class="cr-compound">
        <p class="cr-arc-eyebrow">part three</p>
        <h2 class="font-display cr-arc-title">Compound engineering</h2>
        <p class="cr-arc-sub">
          Every annotation you make is saved to disk. Point an agent at that history, and the
          feedback you keep repeating turns into a custom review skill — caught before you ever
          see it again.
        </p>

        <div class="cr-loop">
          <div class="cr-loop-node">
            <span class="cr-loop-step">01</span>
            <h3 class="cr-loop-title">You annotate</h3>
            <p class="cr-loop-body">
              Every note is written to <code>~/.plannotator</code>, review after review — a growing
              record of what you actually care about.
            </p>
          </div>
          <span class="cr-loop-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" /></svg>
          </span>
          <div class="cr-loop-node">
            <span class="cr-loop-step">02</span>
            <h3 class="cr-loop-title">Distill a skill</h3>
            <p class="cr-loop-body">
              Point an agent at that history. The feedback you give again and again becomes a
              custom review skill, in your own words.
            </p>
          </div>
          <span class="cr-loop-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" /></svg>
          </span>
          <div class="cr-loop-node">
            <span class="cr-loop-step">03</span>
            <h3 class="cr-loop-title">It reviews for you</h3>
            <p class="cr-loop-body">
              The skill runs as a review agent and leaves the note inline, on the diff — so the
              next agent gets it right the first time.
            </p>
          </div>
        </div>

        <div class="cr-loop-return" aria-hidden="true">
          <svg class="cr-loop-return-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v6h6M20 20v-6h-6M20 10a8 8 0 0 0-14.9-3M4 14a8 8 0 0 0 14.9 3" /></svg>
          <span class="cr-loop-return-label">the same feedback, caught automatically — never typed twice</span>
        </div>
      </section>

      <!-- ── CTA ── -->
      <section class="cr-cta">
        <h2 class="font-display cr-title">Two minutes to your first review</h2>
        <p class="cr-body">
          Install once and <code class="cr-inline-cmd">/plannotator-review</code> works from
          Claude Code, OpenCode, Codex, Pi, Copilot CLI, Droid, and more.
        </p>
        <div class="cr-cta-actions">
          <a href="/docs/getting-started/installation/" class="cr-btn">
            Install Plannotator
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="/docs/commands/code-review/" class="cr-btn cr-btn-outline">Read the docs</a>
        </div>
      </section>
    </main>

    <!-- ── Demo video modal ── -->
    <div class="cr-demo-modal" data-demo-modal hidden>
      <div class="cr-demo-backdrop" data-close-demo></div>
      <div class="cr-demo-dialog" role="dialog" aria-modal="true" aria-label="Code review demo">
        <button class="cr-demo-close" type="button" aria-label="Close" data-close-demo>&times;</button>
        <video
          class="cr-demo-video"
          controls
          playsinline
          preload="none"
          poster="/assets/code-review-demo-poster.jpg"
          src="/assets/code-review-demo.mp4"
        ></video>
      </div>
    </div>

    <!-- ── Screenshot lightbox ── -->
    <div class="cr-lightbox" data-lightbox-modal hidden>
      <div class="cr-demo-backdrop" data-close-lightbox></div>
      <div class="cr-lightbox-dialog" role="dialog" aria-modal="true" aria-label="Screenshot">
        <button class="cr-demo-close" type="button" aria-label="Close" data-close-lightbox>&times;</button>
        <img class="cr-lightbox-img" alt="" />
      </div>
    </div>

    <script is:inline>
      (() => {
        // Demo video modal
        const modal = document.querySelector('[data-demo-modal]');
        const video = modal?.querySelector('video');
        const openDemo = () => {
          if (!modal) return;
          modal.hidden = false;
          document.body.style.overflow = 'hidden';
          if (video) video.play().catch(() => {});
        };
        const closeDemo = () => {
          if (!modal) return;
          modal.hidden = true;
          document.body.style.overflow = '';
          if (video) video.pause();
        };
        document.querySelectorAll('[data-open-demo]').forEach((b) => b.addEventListener('click', openDemo));
        document.querySelectorAll('[data-close-demo]').forEach((b) => b.addEventListener('click', closeDemo));

        // Screenshot lightbox
        const lb = document.querySelector('[data-lightbox-modal]');
        const lbImg = lb?.querySelector('.cr-lightbox-img');
        const openLightbox = (src, alt) => {
          if (!lb || !lbImg) return;
          lbImg.src = src;
          lbImg.alt = alt || '';
          lb.hidden = false;
          document.body.style.overflow = 'hidden';
        };
        const closeLightbox = () => {
          if (!lb) return;
          lb.hidden = true;
          document.body.style.overflow = '';
          if (lbImg) lbImg.removeAttribute('src');
        };
        document.querySelectorAll('[data-lightbox]').forEach((b) =>
          b.addEventListener('click', () =>
            openLightbox(b.getAttribute('data-lightbox'), b.getAttribute('data-lightbox-alt')),
          ),
        );
        document.querySelectorAll('[data-close-lightbox]').forEach((b) => b.addEventListener('click', closeLightbox));

        document.addEventListener('keydown', (e) => {
          if (e.key !== 'Escape') return;
          if (modal && !modal.hidden) closeDemo();
          if (lb && !lb.hidden) closeLightbox();
        });
      })();
    </script>

    <Footer />
  </div>
</Base>

